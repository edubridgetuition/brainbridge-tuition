rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    
    // Check if any user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is the master SuperAdmin
    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'superadmin@edubridge.internal' || 
        request.auth.token.email == 'admin@edubridge.com'
      );
    }

    // Check if the user is the guest lookup account
    function isGuest() {
      return isAuthenticated() && request.auth.token.email == 'guest@edubridge.com';
    }

    // Check if the authenticated user belongs to the requested tenant.
    // Tenant users' virtual emails contain the tenantId (e.g., owner_akash_academy_... or staff_akash_academy_...)
    function belongsToTenant(tenantId) {
      return isAuthenticated() && (
        isSuperAdmin() ||
        request.auth.token.email.matches('^owner_' + tenantId.lower() + '_.*') ||
        request.auth.token.email.matches('^staff_' + tenantId.lower() + '_.*') ||
        request.auth.token.email.matches('^student_' + tenantId.lower() + '_.*')
      );
    }

    // --- RULES FOR COLLECTIONS ---

    // 1. Tenants Collection (Root level)
    match /tenants/{tenantId} {
      // Guests can read tenant metadata (like center name, logo, features) to initialize/login
      // Tenant users and SuperAdmin can read
      allow read: if isSuperAdmin() || isGuest() || belongsToTenant(tenantId);
      
      // Anyone using the guest account (on the registration form) or SuperAdmin can register a new tenant
      allow create: if isSuperAdmin() || isGuest();
      
      // Only SuperAdmin or the Tenant Owner can modify tenant configuration
      allow update, delete: if isSuperAdmin() || (isAuthenticated() && request.auth.token.email.matches('^owner_' + tenantId.lower() + '_.*'));

      // 2. Staff Accounts Subcollection
      match /staff_accounts/{staffId} {
        // Guest is allowed to read specific staff documents to perform login validation
        allow read: if isGuest() || belongsToTenant(tenantId);
        // Guests or tenant users can register a new pending staff account
        allow create: if isGuest() || belongsToTenant(tenantId);
        // Writing/modifying requires belonging to the tenant (Owners/Managers)
        allow update, delete: if belongsToTenant(tenantId);
      }

      // 3. Parent Accounts Subcollection
      match /parent_accounts/{studentId} {
        // Guest is allowed to read specific parent documents to verify password hashes
        allow read: if isGuest() || belongsToTenant(tenantId);
        // Guest can register a new parent account
        allow create: if isGuest() || belongsToTenant(tenantId);
        // Modifying/deleting requires belonging to the tenant
        allow update, delete: if belongsToTenant(tenantId);
      }

      // 4. Inquiries Subcollection
      match /inquiries/{inquiryId} {
        // Anyone (public/unauthenticated) can submit an inquiry form
        allow create: if true;
        // Reading/modifying inquiries requires belonging to the tenant (staff/owners)
        allow read, update, delete: if belongsToTenant(tenantId);
      }

      // 5. General Tenant Subcollections (batches, students, attendance, fees, tests, test_marks, testimonials, timetable, homework, study_material, logs, chats, notifications)
      match /{collectionName}/{documentId} {
        // Guest account is strictly forbidden from accessing any academic, fee, or attendance data!
        allow read, write: if belongsToTenant(tenantId) && !isGuest();
      }
    }
  }
}
